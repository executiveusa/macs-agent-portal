{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "macs-agent-portal",
  "main": "./src/cloudflare-worker.ts",
  "compatibility_date": "2026-06-22",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
