NODE_ENV=production
HOST=0.0.0.0
PORT=8787

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STACY_ALLOWED_EMAILS=

OPENROUTER_API_KEY=
FIRECRAWL_API_KEY=
OPUSCLIP_API_KEY=

MAXX_ICM_ROOT=/data/maxx
PI_EXECUTABLE=
MAXX_BROWSER_WS_ENDPOINT=
CONTROL_TOWER_ALLOWED_ORIGINS=https://your-public-agent-maxx-domain.example

# Optional voice provider adapter values. Leave unset to use browser fallback.
# MAXX_STT_ENDPOINT/MAXX_TTS_ENDPOINT are generic HTTP endpoints (POST
# {endpoint}/transcribe, POST {endpoint}/synthesize) - no specific vendor
# (Deepgram, ElevenLabs, etc.) is wired in yet.
MAXX_STT_ENDPOINT=
MAXX_STT_API_KEY=
MAXX_TTS_ENDPOINT=
MAXX_TTS_API_KEY=

# Phase 3: Feature flags (safe rollout). All default to false/disabled.
MAXX_HERMES_ENABLED=false
MAXX_VOICE_ENABLED=false
MAXX_BROWSER_ENABLED=false
MAXX_BROWSER_MUTATIONS_ENABLED=false
MAXX_MEMORY_ENABLED=false
MAXX_SCHEDULER_ENABLED=false

# Production mutation lock. Must be explicitly set to true before writes are
# allowed in a production deployment (POST/PATCH/PUT/DELETE).
MAXX_PRODUCTION_MUTATIONS_ENABLED=false

# System-wide kill switch. When true, all mutating routes return 503 regardless
# of environment. Restart the control plane to re-enable.
MAXX_EMERGENCY_DISABLE=false

# Phase 4: Approval TTL. Pending approvals older than this are treated as
# expired and can no longer be approved/rejected (anti-replay + timeout).
MAXX_APPROVAL_TTL_HOURS=24

# Phase 5: Hermes agent runtime. Requires MAXX_HERMES_ENABLED=true above AND
# this endpoint to actually run agents; otherwise routes report an honest
# 503/failed state instead of hanging.
MAXX_HERMES_ENDPOINT=

# Phase 6: Memory indexer. Keyword-indexed mission memory (JSONL), not a
# vector store - no embedding provider key is configured in this environment.
# Defaults to <MAXX_ICM_ROOT>/memory/index.jsonl when unset.
MAXX_MEMORY_INDEX_PATH=
